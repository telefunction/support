{
    "name": "telefunction/support",
    "description": "Reusable foundations and utilities for Telefunction packages.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "telefunction",
        "laravel",
        "support",
        "helpers"
    ],
    "authors": [
        {
            "name": "Telefunction",
            "role": "Owner"
        }
    ],
    "require": {
        "php": "^8.3",
        "laravel/framework": "^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Telefunction\\Support\\": "src/"
        }
    },
    "scripts": {
        "format": "pint",
        "format:test": "pint --test",
        "analyse": "phpstan analyse --memory-limit=-1",
        "check": [
            "@format:test",
            "@analyse"
        ],
        "fix": [
            "@format"
        ]
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
